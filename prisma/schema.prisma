generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  calculations  Calculation[]
}

model Calculation {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  calculatorType String   @default("pid")
  businessType   String?
  inputs         String   // Using String since SQLite doesn't natively support JSON
  results        String   // Using String since SQLite doesn't natively support JSON
  createdAt      DateTime @default(now())
}
